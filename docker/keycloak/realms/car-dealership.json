{
  "realm": "car-dealership",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "USER" },
      { "name": "MANAGER" },
      { "name": "WAREHOUSE_ADMIN" },
      { "name": "ADMIN" }
    ]
  },
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "email": "user1@example.com",
      "firstName": "User",
      "lastName": "One",
      "createdTimestamp": 1680000000000,
      "credentials": [{ "type": "password", "value": "user1" }],
      "realmRoles": ["USER"]
    },
    {
      "username": "user2",
      "enabled": true,
      "email": "user2@example.com",
      "firstName": "User",
      "lastName": "Two",
      "createdTimestamp": 1680000000000,
      "credentials": [{ "type": "password", "value": "user2" }],
      "realmRoles": ["USER"]
    }
  ,
    {
      "username": "manager1",
      "enabled": true,
      "firstName": "Manager",
      "lastName": "One",
      "email": "manager1@example.com",
      "createdTimestamp": 1680000000001,
      "credentials": [{ "type": "password", "value": "manager1" }],
      "realmRoles": ["MANAGER"]
    },
    {
      "username": "warehouse1",
      "enabled": true,
      "firstName": "Warehouse",
      "lastName": "One",
      "email": "warehouse1@example.com",
      "createdTimestamp": 1680000000002,
      "credentials": [{ "type": "password", "value": "warehouse1" }],
      "realmRoles": ["WAREHOUSE_ADMIN"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "firstName": "Admin",
      "lastName": "One",
      "email": "admin1@example.com",
      "createdTimestamp": 1680000000003,
      "credentials": [{ "type": "password", "value": "admin1" }],
      "realmRoles": ["ADMIN"]
    }
  ],
  "clients": [
    {
      "clientId": "car-api",
      "enabled": true,
      "publicClient": false,
      "secret": "secret",
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "roles"],
      "attributes": {
        "access.token.claim.roles": "true"
      }
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "preferred-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "id",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}